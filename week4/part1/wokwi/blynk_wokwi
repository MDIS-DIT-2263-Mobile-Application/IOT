#define BLYNK_TEMPLATE_ID "YOUR OWN ID"
#define BLYNK_TEMPLATE_NAME "ESP32 DHT22 Wokwi"
#define BLYNK_AUTH_TOKEN "YOUR OWN TOKEN"

#include "DHT.h"
#include <HTTPClient.h>
#include <WiFi.h>
#include <WiFiClient.h>
#include <BlynkSimpleEsp32.h>


#define DHTPIN 18     
#define DHTTYPE DHT22   // DHT 22  (AM2302), AM2321

DHT dht(DHTPIN, DHTTYPE);

#define ssid "Wokwi-GUEST"
#define password ""

BlynkTimer timer;


void sendTemp() {
  
  float temperature = dht.readTemperature();
  float humidity = dht.readHumidity();
  if (!isnan(temperature)) {
    Blynk.virtualWrite(V0, temperature);       // Push to widget on V0
    Blynk.virtualWrite(V1, humidity);       // Push to widget on V1
    Serial.println("Blynk: " + String(temperature));
  }
}


void setup() {
  Serial.begin(115200);
  Serial.println(F("DHT22 example!"));

  dht.begin();

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, password);      // Connects WiFi + Blynk
  timer.setInterval(2000, sendTemp); // Every 2 seconds
}

void loop() {
  Blynk.run();
  timer.run();
}
